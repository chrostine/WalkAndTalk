---
// src/components/ChatBox.astro
---

<div class="flex flex-col h-screen py-5 font-kurssiv text-lg">
  <div class="flex flex-col mt-auto w-full">
    <div id="messages-wrapper" class="relative" style="height: 400px;">
      <div
        id="messages"
        class="flex flex-col justify-end h-full overflow-y-scroll gap-2 p-3 w-full [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        <!-- Beskeder bliver tilføjet her af scriptet -->
      </div>
    </div>

    <form id="chat-form" class="flex gap-2 p-3">
      <input
        id="chat-input"
        type="text"
        placeholder="Hvordan har du det i dag?"
        autocomplete="off"
        class="flex-1 px-3 py-2 bg-hvid rounded-2xl disabled:opacity-60 disabled:cursor-not-allowed outline-none focus:ring-1 focus:ring-sort"
      />
      <button
        type="submit"
        class="px-4 py-2 rounded-2xl bg-gron text-white cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed border border-transparent hover:border-sort"
      >
        SEND
      </button>
    </form>
  </div>
</div>

<script>
  type Message = { role: "user" | "assistant"; text: string };

  const messages: Message[] = [];

  const messagesEl = document.getElementById("messages") as HTMLDivElement;
  const wrapperEl = document.getElementById(
    "messages-wrapper",
  ) as HTMLDivElement;
  const formEl = document.getElementById("chat-form") as HTMLFormElement;
  const inputEl = document.getElementById("chat-input") as HTMLInputElement;

  // ── Justerbare variabler ──────────────────────────
  const TYPEWRITER_SPEED_MS = 30; // ms per bogstav
  const FADE_THRESHOLD_PX = 200; // samlet indholdshøjde før fade aktiveres
  const FADE_SIZE_PX = 100; // hvor mange px fade-effekten strækker sig
  // ─────────────────────────────────────────────────

  const baseBubbleClasses = [
    "max-w-[80%]",
    "px-3",
    "py-2",
    "rounded-md",
    "break-words",
  ];
  const userBubbleClasses = ["self-end", "bg-blaa", "text-sort"];
  const assistantBubbleClasses = ["self-start", "bg-hvid", "text-sort"];

  function updateFade() {
    console.log("wrapper højde:", wrapperEl.clientHeight);
    console.log("scroll højde:", messagesEl.scrollHeight);
    if (messagesEl.scrollHeight > FADE_THRESHOLD_PX) {
      wrapperEl.style.maskImage = `linear-gradient(to bottom, transparent, black ${FADE_SIZE_PX}px, black 100%)`;
      wrapperEl.style.webkitMaskImage = `linear-gradient(to bottom, transparent, black ${FADE_SIZE_PX}px, black 100%)`;
    } else {
      wrapperEl.style.maskImage = "";
      wrapperEl.style.webkitMaskImage = "";
    }
  }

  function renderMessage(message: Message) {
    const bubble = document.createElement("div");
    bubble.classList.add(...baseBubbleClasses);
    bubble.classList.add(
      ...(message.role === "user" ? userBubbleClasses : assistantBubbleClasses),
    );
    bubble.textContent = message.text;
    messagesEl.appendChild(bubble);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    updateFade();
  }

  function typewriterMessage(message: Message) {
    const bubble = document.createElement("div");
    bubble.classList.add(...baseBubbleClasses);
    bubble.classList.add(...assistantBubbleClasses);
    messagesEl.appendChild(bubble);

    let i = 0;
    const interval = setInterval(() => {
      bubble.textContent += message.text[i];
      i++;
      messagesEl.scrollTop = messagesEl.scrollHeight;
      updateFade();

      if (i >= message.text.length) {
        clearInterval(interval);
      }
    }, TYPEWRITER_SPEED_MS);
  }

  function setLoading(isLoading: boolean) {
    inputEl.disabled = isLoading;
    const button = formEl.querySelector("button") as HTMLButtonElement;
    button.disabled = isLoading;
    button.textContent = isLoading ? "..." : "Send";
  }

  formEl.addEventListener("submit", async (event) => {
    event.preventDefault();

    const text = inputEl.value.trim();
    if (!text) return;

    const userMessage: Message = { role: "user", text };
    messages.push(userMessage);
    renderMessage(userMessage);

    inputEl.value = "";
    setLoading(true);

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages }),
      });

      if (!response.ok) {
        throw new Error("Noget gik galt med kaldet til /api/chat");
      }

      const data = await response.json();
      const assistantMessage: Message = { role: "assistant", text: data.reply };
      messages.push(assistantMessage);
      typewriterMessage(assistantMessage);
    } catch (error) {
      console.error(error);
      renderMessage({
        role: "assistant",
        text: "Beklager, der opstod en fejl. Prøv igen.",
      });
    } finally {
      setLoading(false);
      inputEl.focus();
    }
  });
</script>
