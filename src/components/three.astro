<canvas id="three-bg"></canvas>

<style>
  #three-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>

<script>
  import { initBackground } from "../scripts/three.js";

  const canvas = document.getElementById("three-bg") as HTMLCanvasElement;
  initBackground(canvas);
</script>
